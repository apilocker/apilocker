# ---- Dependencies ----
node_modules/
jspm_packages/

# ---- Build output ----
dist/
build/
*.tsbuildinfo

# ---- Cloudflare Workers / wrangler ----
.wrangler/
.dev.vars
.dev.vars.*
worker-configuration.d.ts

# ---- Environment & secrets ----
# We don't use .env files in this repo (the whole point of API Locker is to
# replace them), but these globs are here as belt-and-suspenders so no one
# accidentally commits a secret.
.env
.env.*
*.env
!.env.example
.envrc
*.pem
*.key
*.crt
secrets.json
credentials.json

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ---- Windows ----
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# ---- Local scratch files (internal working docs, one-off scripts) ----
SESSION_STATUS.md
rotate-fix.sh
*.local.md
scratch/
tmp/

# mcp-publisher CLI auth tokens — created by 'mcp-publisher login'
# Contains a GitHub user OAuth token + MCP Registry JWT. NEVER commit.
.mcpregistry_github_token
.mcpregistry_registry_token

# Internal submission/review notes — contain test account info,
# reviewer-only links, etc. Not for the public repo.
ANTHROPIC_SUBMISSION.md
